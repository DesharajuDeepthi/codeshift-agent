# UpgradePilot environment configuration — copy to .env and fill in values.
# Never commit .env.

# Application
UPGRADEPILOT_ENV=dev
UPGRADEPILOT_VERSION=0.1.0
UPGRADEPILOT_GIT_SHA=unknown

# LangSmith (https://smith.langchain.com)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=upgradepilot-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false

# LLM provider
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# GitHub (optional — used for higher rate limits)
GITHUB_TOKEN=

# PostgreSQL
# SECURITY: POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB default to local
# development values in docker-compose.yml. Override all three with strong
# credentials before running in any shared, staging, or production environment.
POSTGRES_USER=upgradepilot
POSTGRES_PASSWORD=upgradepilot
POSTGRES_DB=upgradepilot
# DATABASE_URL is constructed from the above in docker-compose.yml.
# Set it explicitly here if running the API outside of Docker Compose.
DATABASE_URL=postgresql+psycopg://upgradepilot:upgradepilot@postgres:5432/upgradepilot

# Redis
REDIS_URL=redis://redis:6379/0

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
UI_PORT=8501
# API base used by Streamlit. Docker Compose sets API_URL=http://api:8000.
UPGRADEPILOT_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# Grafana
# SECURITY: Override GRAFANA_ADMIN_PASSWORD with a strong password before any
# non-local deployment. The default "admin" must not be used in production.
GRAFANA_ADMIN_PASSWORD=admin

# Safety limits
MAX_ARCHIVE_COMPRESSED_BYTES=104857600
MAX_ARCHIVE_EXTRACTED_BYTES=524288000
MAX_ARCHIVE_FILE_COUNT=10000
MAX_PATH_DEPTH=20
MAX_SINGLE_FILE_BYTES=5242880
ANALYSIS_TIMEOUT_SECONDS=120
